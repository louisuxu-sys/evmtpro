# LINE BOT 設定
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# 伺服器設定
PORT=3000

# LINE 通知目標 (群組ID 或 使用者ID，多個用逗號分隔)
LINE_NOTIFY_TARGETS=

# EV 警報閾值 (絕對值超過此值時發送通知)
EV_ALERT_THRESHOLD=0.01

# ===== 被動模式 (Render 部署用) =====
# MT_MODE=passive → 不啟動 Puppeteer，等待本地攔截器推送資料
MT_MODE=passive

# API 金鑰 (本地攔截器與 Render 端設定需相同)
INGEST_API_KEY=your_secret_key_here
